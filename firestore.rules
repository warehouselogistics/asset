rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ต้องล็อกอิน (Anonymous Auth นับเป็นล็อกอิน) จึงอ่าน-เขียนได้
    function signedIn() { return request.auth != null; }

    match /drivers/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /tx/{id} {
      allow read, create: if signedIn();
      // รายการเคลื่อนไหวห้ามแก้/ลบจากหน้าแอป กันการแอบแก้ยอดย้อนหลัง
      // (การลบคนขับใช้ batch ฝั่ง client จึงต้องเปิด delete — ถ้าเข้มสุดให้ปิดบรรทัดนี้)
      allow delete: if signedIn();
      allow update: if false;
    }

    match /incidents/{id} {
      allow read, create: if signedIn();
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if false;
    }

    match /meta/settings {
      allow read, write: if signedIn();
    }

    match /{document=**} { allow read, write: if false; }
  }
}
